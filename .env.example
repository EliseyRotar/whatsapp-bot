# Bot Configuration
PREFIX=.
BOT_NAME=eli6s bot
OWNER_NAME=eli6
OWNER_NUMBER=393313444410
OWNER_JID=222788929462360@lid

# Bot Settings
AUTO_READ=false
AUTO_TYPING=false
AUTO_REACT=false
MODE=public

# Spam Settings (IMPORTANT: Low values can cause WhatsApp bans!)
SPAM_DELAY=3000
MAX_SPAM_COUNT=50

# Warning System
MAX_WARNINGS=3

# AI Settings
AI_PROVIDER=groq
OPENROUTER_API_KEY=your_openrouter_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Trading API
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# Web Dashboard
WEB_PASSWORD=admin123
WEB_PORT=3000
JWT_SECRET=change-this-to-a-random-secret-key-at-least-32-characters

# Database
DB_TYPE=sqlite
DB_PATH=./data/bot.db

# Redis (for message queue)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# YouTube Download Configuration (Optional)
YOUTUBE_DELAY_BETWEEN_REQUESTS=1000
YOUTUBE_MAX_RETRIES=3
YOUTUBE_RETRY_DELAY=2000
MAX_AUDIO_SIZE_MB=50
MAX_VIDEO_SIZE_MB=60
DOWNLOAD_TIMEOUT_SECONDS=600
YOUTUBE_DEBUG=false
ENABLE_USER_AGENT_ROTATION=true
FORCE_DISABLE_YTDLP=false

# RapidAPI Key (Optional - for YouTube downloads when yt-dlp fails)
# Get your free key at: https://rapidapi.com/
RAPIDAPI_KEY=your_rapidapi_key_here

# Social Media APIs (Optional)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here
PIN_KEY=your_pinterest_api_key_here
